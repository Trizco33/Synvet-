# ============================================================
# Synvet — Variáveis de ambiente (template)
# ============================================================
# Copie para `.env.local` e preencha com seus valores reais.
# NUNCA commite .env.local — apenas este arquivo (.env.example).
#
# No Replit: configure via "Secrets" (ou em .replit > [userenv]
# para valores PÚBLICOS apenas).
# Em produção (Replit Deployments): adicione as mesmas chaves
# em "Deployment Secrets" antes do publish.
# ============================================================

# ----------------------------------------------------------------
# OBRIGATÓRIAS
# ----------------------------------------------------------------

# Postgres (provisionado pelo Replit Database em dev; Supabase/Neon
# em produção se migrar). String completa de conexão.
DATABASE_URL=postgresql://user:password@host:5432/database

# Sessão / cookies — gerar com: openssl rand -base64 48
SESSION_SECRET=troque-por-um-valor-aleatorio-de-pelo-menos-32-bytes


# ----------------------------------------------------------------
# SUPABASE — Auth + Storage
# ----------------------------------------------------------------
# Sem estas o backend cai automaticamente em modo demo (apenas dev).
# NODE_ENV=production bloqueia o modo demo (retorna 401).

# Servidor (NUNCA expor no bundle do frontend)
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cliente (vai para o bundle do Vite — usar SOMENTE chave anon)
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ----------------------------------------------------------------
# OPCIONAIS / FEATURE FLAGS
# ----------------------------------------------------------------

# Permite o modo demo mesmo em production (NÃO usar em produção real)
# ALLOW_DEMO_AUTH=true

# Definido automaticamente pelos workflows do Replit; documentado aqui
# para clareza. Cada artefato escuta na porta atribuída pelo sistema.
# PORT=8080
# BASE_PATH=/

# Em deployment, defina explicitamente para ativar logs e modo correto:
# NODE_ENV=production

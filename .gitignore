# ============================================================
# Synvet — .gitignore
# ============================================================

# ---- Build outputs --------------------------------------------------
dist/
build/
out-tsc/
*.tsbuildinfo
.expo
.expo-shared
coverage/
.nyc_output/

# ---- Dependencies --------------------------------------------------
node_modules/

# ---- Environment / secrets (NUNCA commitar) ------------------------
# Apenas .env.example é commitado.
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
.env.test
**/.env
**/.env.local
**/.env.*.local

# ---- Logs ----------------------------------------------------------
*.log
npm-debug.log*
yarn-error.log*
pnpm-debug.log*
testem.log

# ---- IDEs / editores -----------------------------------------------
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ---- Sistema operacional -------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ---- Caches diversos -----------------------------------------------
.sass-cache/
.parcel-cache/
.turbo/
.swc/
.eslintcache
.stylelintcache

# ---- Tooling do agente Replit (não fazem sentido fora) -------------
.cache/
.local/
.agents/
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# ---- Artefatos temporários do projeto ------------------------------
/tmp/
*.tmp
*.bak
*.old

modules = ["nodejs-24", "postgresql-16", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 24341
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
VITE_SUPABASE_URL = "https://bzvuhycbtwdkhvkxsypu.supabase.co"
SUPABASE_URL = "https://bzvuhycbtwdkhvkxsypu.supabase.co"
STRIPE_PRICE_ESSENCIAL = "price_1TVWmiIEDPpyboWcOeRoMKIS"
STRIPE_PRICE_PRO = "price_1TVWmjIEDPpyboWcdNNQzlwL"
STRIPE_PRICE_CLINIC_PLUS = "price_1TVWmjIEDPpyboWcEYLYHSkm"
